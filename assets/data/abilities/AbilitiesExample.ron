// All ability data lives in this single file. IDs are packed (level << 11 | sub):
// 5 bits of level (0..=30) in the high bits, 11 bits of sub-id in the low bits
// (see `crate::combat_ability::pack_ability_id`). One level band per character
// keeps it obvious who owns what:
//
//   L0  / 0x0000.. — generic / placeholder demo abilities
//   L10 / 0x5000.. — Rina
//   L11 / 0x5800.. — Sayaka
//   L12 / 0x6000.. — Houjou Utaka
//   L13 / 0x6800.. — Toshiko
//   L15 / 0x7800.. — Yokai
//   L16+/ 0x8000.. — magic-school + martial capstones (unlocked via skill trees)
//
// Effects use the new `ApplyStatus { kind, tier }` / `RemoveStatus { kind }`
// variants for non-damage actions (Cleanse, Bind spirit, Whisper, etc.).
[
    // -----------------------------------------------------------------------
    // Demo / placeholder abilities (kept for the existing AI-tree examples).
    // -----------------------------------------------------------------------
    (
        id: 0,
        next_id: None,
        name: "Minor Heal",
        health_cost: 0,
        magic_cost: 8.0,
        magic_school: Kiho,
        action_point_cost: 0,
        cooldown: 1,
        description: "A small mending — a steadying hand and a few murmured words close the worst of a single ally's hurt.",
        effects: [
            Heal(floor: 12, ceiling: 18, scaled_with: Mind),
        ],
        shape: Select,
        duration: 0,
        targets: 1,
    ),
    (
        id: 2050,
