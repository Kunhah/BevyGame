        magic_school: Kiho,
        action_point_cost: 0,
        cooldown: 3,
        description: "A gout of conjured flame hurled out to wash over everything caught in the cone before you.",
        effects: [
            Damage(
                floor: 30,
                ceiling: 50,
                damage_type: Fire,
                scaled_with: Mind,
                defended_with: Mind,
            ),
        ],
        shape: Cone(angle: 60.0, radius: 4.5),
        duration: 0,
        targets: 6,
    ),
    (
        id: 4097,
