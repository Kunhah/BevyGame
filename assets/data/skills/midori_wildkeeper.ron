// Midori — Wildkeeper. A satoyama (里山) caretaker who practises folk onmyōdō:
// the green craft of the wood line (moku, 木) — herbs, sap, and bound talismans
// of leaf and thorn — with a little of the earth line (do, 土). This is
// TECHNIQUE, not communion: she reads and works living matter, she does not
// petition the yama-no-kami (that devotion is Kamishin's). She is a sustain
// support whose identity is regrowth, contrasting Sayaka's divine (Kamishin)
// support: the same "healer" slot, a wholly different source — craft, not
// prayer. Her kin are the mountain's own beasts, who abide one who reads their
// signs — wolf, boar, serpent, deer (the fox belongs to Sayaka's kitsune line).
// IDs: 0xECXX.
//
// WIRING (later): register `SkillTreeKind::MidoriWildkeeper` in
// src/skill_tree.rs and add this path to `SKILL_RON_FILES`.
[
    (
        id: 60416, // 0xEC00
        tree: MidoriWildkeeper,
        tier: 1,
        name: "Green Tongue",
        description: "Reads the slow grammar of growing things and wary beasts, and works it. +5 Mind.",
        cost: 1,
        prerequisites: [],
        effects: [
            StatBonus(target: Mind, amount: 5),
        ],
    ),
    (
        id: 60417, // 0xEC01
        tree: MidoriWildkeeper,
        tier: 1,
