        tree: MidoriWildkeeper,
        tier: 2,
        name: "Escort of Wolves",
        description: "The wild abides one who knows its grammar — the okuri-ōkami at her heel, the boar that breaks her trail. +5 Evasion, +3 Mind.",
        cost: 2,
        prerequisites: [60416],
        effects: [
            StatBonus(target: Evasion, amount: 5),
            StatBonus(target: Mind, amount: 3),
