        tree: MidoriWildkeeper,
        tier: 2,
        name: "Turning of Seasons",
        description: "Keeps the old almanac — the day the mountain's vigor descends to the paddies and the day it climbs back — and times her craft to the turning. +5 Onmyodo max, +5 Morale.",
        cost: 2,
        prerequisites: [60416, 60417],
        effects: [
            StatBonus(target: Onmyodo, amount: 5),
